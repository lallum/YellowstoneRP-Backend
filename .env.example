# Railway / StonePineRP backend
PORT=3100
NODE_ENV=production

# Supabase PostgreSQL connection string. Keep this secret in Railway Variables.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
DATABASE_SSL=true
DB_POOL_MAX=8
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000

# Use a long random value (64+ characters recommended).
STONEPINERP_API_KEY=REPLACE_WITH_A_LONG_PRIVATE_SERVER_KEY

# Legacy aliases remain supported so the existing Yellowstone deployment does not break.
YELLOWSTONERP_API_KEY=
STONEPINERP_SERVER_ID=stonepine-rp-glenwood-main
# Development only. Keep false on a public server.
STONEPINERP_ALLOW_TEST_WHITELIST_BYPASS=false
YELLOWSTONERP_SERVER_ID=

# Optional Discord logging
COURT_DISCORD_WEBHOOK_URL=
JAIL_DISCORD_WEBHOOK_URL=
