{
  "name": "yellowstonerp-backend",
  "version": "1.0.0-standalone-v14-railway-supabase-lowms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "echo Build skipped - using uploaded dist folder",
    "db:init": "psql \"$DATABASE_URL\" -f ../database/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f ../database/seed_properties.sql",
    "db:reset": "npm run db:fresh",
    "db:fresh": "npm run db:init && npm run db:seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
